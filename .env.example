# API Endpoint
# Point to your OpenAI-compatible API gateway, or use Anthropic directly
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# Models
EXTRACTION_MODEL=claude-4.6-sonnet
SYNTHESIS_MODEL=claude-4.6-opus
REFINEMENT_MODEL=claude-4.6-opus
EMBEDDING_MODEL=text-embedding-3-large

# Infrastructure
DATABASE_URL=postgresql://archaeologist:archaeologist@localhost:5432/session_archaeologist
REDIS_URL=redis://localhost:6379/0

# Pipeline
MAX_PARALLEL_EXTRACTIONS=5
COST_CONFIRMATION_THRESHOLD=5.00
CHUNK_TARGET_TOKENS=120000
CHUNK_OVERLAP_TOKENS=15000
